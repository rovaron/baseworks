DATABASE_URL=postgres://baseworks:baseworks@localhost:5432/baseworks
NODE_ENV=development
PORT=3000
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

# Postgres connection pool cap (optional, default 10). Read directly by
# packages/db/src/connection.ts (createDb). Tune up for high-concurrency
# deployments; keep below your Postgres max_connections.
DB_POOL_MAX=10

# Instance role (optional, default "all"). "api" serves HTTP only, "worker"
# processes BullMQ jobs only, "all" does both. REDIS_URL becomes required for
# "worker" and "all".
INSTANCE_ROLE=all

# Auth (required)
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Platform-admin allowlist (optional). Comma-separated email addresses granted
# operator scope independent of organization role. Empty = no platform admins.
# Example: ADMIN_EMAILS=alice@example.com,ops@example.com
ADMIN_EMAILS=

# Frontend URLs (required for CORS and auth trusted origins)
WEB_URL=http://localhost:3001
ADMIN_URL=http://localhost:5173

# Worker health check port (optional, default 3001)
WORKER_HEALTH_PORT=3001

# Phase 22 — Bull-board read-only mode (default "true" — flip to "false" only on a
# deployment where operators need to retry/promote/remove jobs from the BullMQ UI).
# Invalid values (anything other than "true"/"false") crash the API at boot.
BULL_BOARD_READ_ONLY=true

# Phase 22 — Worker heartbeat publish interval in ms (default 15000, min 1000, max 300000).
# TTL on heartbeat keys is 2× this value; "stale" threshold is 2×, "dead" is 5×.
# Workers publish to Redis key `worker:heartbeat:{instanceId}` on this cadence.
WORKER_HEARTBEAT_INTERVAL_MS=15000

# OAuth (optional -- auth works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Payments (required for boot -- PAYMENT_PROVIDER defaults to "stripe").
# For local dev without real payments, any non-empty value satisfies
# validatePaymentProviderEnv(). Use a real sk_test_... key to exercise
# Stripe flows end-to-end. See packages/config/src/env.ts for the full
# validator.
#
# The active provider's secret key AND webhook signing secret are both
# REQUIRED at boot (validatePaymentProviderEnv throws otherwise, except under
# NODE_ENV=test which only warns). Set the Stripe pair when PAYMENT_PROVIDER=stripe,
# or the Pagar.me pair when PAYMENT_PROVIDER=pagarme.
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_dummy_replace_for_real_stripe_flows
# Stripe webhook signing secret (whsec_...) used by stripe.webhooks.constructEvent().
# Required when PAYMENT_PROVIDER=stripe.
STRIPE_WEBHOOK_SECRET=whsec_dummy_replace_for_real_stripe_flows
# Pagar.me secrets (only required when PAYMENT_PROVIDER=pagarme).
PAGARME_SECRET_KEY=
PAGARME_WEBHOOK_SECRET=

# Observability (optional -- defaults are dev-safe).
# ERROR_TRACKER selects the error-tracking adapter: "pino" (default, logs only),
# "noop", "sentry", or "glitchtip". Choosing "sentry"/"glitchtip" makes the
# matching DSN below REQUIRED at boot (validateObservabilityEnv throws otherwise).
# TRACER and METRICS_PROVIDER are "noop" only for now.
ERROR_TRACKER=pino
TRACER=noop
METRICS_PROVIDER=noop
# Sentry DSN (required when ERROR_TRACKER=sentry).
SENTRY_DSN=
# GlitchTip DSN (required when ERROR_TRACKER=glitchtip).
GLITCHTIP_DSN=
# Release identifier attached to error events (optional, e.g. a git SHA or version).
RELEASE=
# Environment tag reported to Sentry/GlitchTip (optional, e.g. production/staging).
SENTRY_ENVIRONMENT=
# Extra comma-separated keys to scrub from logs/error payloads on top of the
# built-in PII deny-list (optional).
OBS_PII_DENY_EXTRA_KEYS=

# Email (optional -- transactional emails fall back to console log)
RESEND_API_KEY=

# Phase 24 — File storage adapter (defaults to local for dev DX).
# Production deployments MUST set STORAGE_PROVIDER=s3 or s3-compat;
# validateStorageEnv() crashes at boot if STORAGE_PROVIDER=local && NODE_ENV=production
# (Pitfall 14 / D-14).
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage

# Phase 24 — Per-tenant storage quota in bytes (default 1 GiB / 1073741824).
# Per-tenant override available via tenant_storage_usage.bytes_limit row column (D-11).
STORAGE_DEFAULT_QUOTA_BYTES=1073741824

# Phase 24 — Image transform adapter (default sharp; Phase 28 may flip this
# if the Bun smoke test goes RED — D-12).
IMAGE_TRANSFORM_PROVIDER=sharp

# Phase 24 — S3 / S3-compatible adapter env (only required when
# STORAGE_PROVIDER=s3 or s3-compat). Bodies arrive in Phase 25.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=true
