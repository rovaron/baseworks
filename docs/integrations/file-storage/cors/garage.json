{
  "CORSRules": [
    {
      "AllowedOrigins": ["https://app.example.com", "http://localhost:3000"],
      "AllowedMethods": ["PUT", "POST", "GET", "HEAD"],
      "AllowedHeaders": [
        "content-type",
        "content-length",
        "x-amz-checksum-sha256",
        "x-amz-meta-tenant-id"
      ],
      "ExposeHeaders": ["ETag"],
      "MaxAgeSeconds": 3600
    }
  ]
}
